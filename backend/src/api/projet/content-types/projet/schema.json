    },
    "technologies": {
      "type": "json"
    },
    "lien_repo": {
      "type": "string"
    },
    "lien_demo": {
      "type": "string"
    },
    "image": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "date_realisation": {
      "type": "date"
    }
  }
